---
const currentPath = Astro.url.pathname;
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/ideas', label: 'Ideas' },
  { href: '/research', label: 'Research' },
  { href: '/recognition', label: 'Recognition' },
  { href: '/about', label: 'About' },
];
const socialLinks = [
  { href: 'https://twitter.com/sugaroverflow', label: 'Twitter', icon: '↗' },
  { href: 'https://www.linkedin.com/in/sugaroverflow', label: 'LinkedIn', icon: '↗' },
  { href: 'https://github.com/sugaroverflow', label: 'GitHub', icon: '↗' },
];
---

<header data-site-header>
  <nav class="hidden md:block fixed left-0 top-0 h-screen w-64 bg-neutral-50 border-r border-neutral-300 p-8">
    <a href="/" class="text-2xl font-serif text-sage-900">sugaroverflow</a>

    <ul class="mt-12 space-y-4">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class={`text-neutral-900 hover:text-lilac-700 transition-colors ${
              currentPath === item.href ? 'font-semibold text-lilac-700' : ''
            }`}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="absolute bottom-8 left-8">
      <p class="text-sm text-neutral-900/60">Fatima Sarah Khalid</p>
      <div class="mt-2 flex flex-col gap-2 text-sm">
        {socialLinks.map((link) => (
          <a
            href={link.href}
            class="flex items-center gap-2 text-neutral-900/70 hover:text-lilac-700"
            target="_blank"
            rel="noopener noreferrer"
          >
            {link.label}
            <span aria-hidden="true">{link.icon}</span>
          </a>
        ))}
      </div>
    </div>
  </nav>

  <div class="md:hidden border-b border-neutral-200 bg-neutral-50 px-6 py-4">
    <div class="flex items-center justify-between">
      <a href="/" class="text-xl font-serif text-sage-900">sugaroverflow</a>
      <button
        type="button"
        class="rounded-full border border-neutral-300 px-4 py-2 text-sm text-neutral-900/80"
        aria-expanded="false"
        aria-controls="mobile-nav-panel"
        data-mobile-toggle
      >
        Menu
      </button>
    </div>
  </div>

  <div
    id="mobile-nav-panel"
    class="md:hidden fixed inset-0 z-40 hidden"
    role="dialog"
    aria-modal="true"
    data-mobile-panel
  >
    <div class="absolute inset-0 bg-neutral-900/50" data-mobile-overlay></div>
    <div class="absolute right-0 top-0 flex h-full w-72 flex-col bg-neutral-50 p-6 shadow-xl">
      <div class="flex items-center justify-between">
        <p class="text-lg font-serif text-sage-900">sugaroverflow</p>
        <button
          type="button"
          class="text-sm text-neutral-900/70"
          aria-label="Close menu"
          data-mobile-close
        >
          Close
        </button>
      </div>
      <ul class="mt-8 space-y-4">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class={`block text-base text-neutral-900 hover:text-lilac-700 ${
                currentPath === item.href ? 'font-semibold text-lilac-700' : ''
              }`}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
      <div class="mt-auto">
        <p class="text-sm text-neutral-900/60">Find me online</p>
        <div class="mt-4 space-y-3 text-sm">
          {socialLinks.map((link) => (
            <a
              href={link.href}
              class="flex items-center justify-between text-neutral-900/80 hover:text-lilac-700"
              target="_blank"
              rel="noopener noreferrer"
            >
              {link.label}
              <span aria-hidden="true">{link.icon}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  (() => {
    const root = document.currentScript?.closest('[data-site-header]');
    if (!root) return;
    const toggle = root.querySelector('[data-mobile-toggle]');
    const panel = root.querySelector('[data-mobile-panel]');
    const closeBtn = root.querySelector('[data-mobile-close]');
    const overlay = root.querySelector('[data-mobile-overlay]');

    const openMenu = () => {
      if (!panel || !toggle) return;
      panel.classList.remove('hidden');
      toggle.setAttribute('aria-expanded', 'true');
      document.body.classList.add('overflow-hidden');
      panel.querySelector('a, button')?.focus();
    };

    const closeMenu = () => {
      if (!panel || !toggle) return;
      panel.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
      document.body.classList.remove('overflow-hidden');
      toggle.focus();
    };

    toggle?.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      isOpen ? closeMenu() : openMenu();
    });

    closeBtn?.addEventListener('click', closeMenu);
    overlay?.addEventListener('click', closeMenu);
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && toggle?.getAttribute('aria-expanded') === 'true') {
        closeMenu();
      }
    });
  })();
</script>

