---
import type { Post } from '@/lib/types';
import ContentTypeLabel from './ContentTypeLabel.astro';
import TagChip from './TagChip.astro';

interface Props {
  post: Post;
}

const { post } = Astro.props as Props;
---

<article class="p-6 bg-neutral-50 rounded-lg border border-neutral-300 hover:border-lilac-300 transition-colors">
  <div class="flex items-center gap-3 text-sm">
    <ContentTypeLabel type={post.contentType} />
    <time class="text-neutral-900/60">{post.date}</time>
  </div>

  <h3 class="mt-3 text-xl font-serif text-sage-900">
    <a href={`/blog/${post.slug}`} class="hover:text-lilac-700">
      {post.title}
    </a>
  </h3>

  <p class="mt-2 text-neutral-900/80">{post.description}</p>

  <div class="mt-4 flex flex-wrap gap-2">
    {post.topics.map((topic) => (
      <TagChip label={topic} />
    ))}
  </div>
</article>

